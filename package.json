{
  "name": "adonisjs-starter-kit",
  "version": "0.0.2",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint --continue --ui=stream --log-order=grouped",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo typecheck --continue --ui=stream --log-order=grouped",
    "test": "turbo test --continue --ui=stream --log-order=grouped",
    "infra:up": "docker compose --env-file apps/web/.env up -d",
    "infra:down": "docker compose --env-file apps/web/.env down",
    "docker:prod": "docker compose -f docker-compose.yaml -f docker-compose.prod.yaml up -d"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.9.4",
    "turbo": "^2.10.2",
    "typescript": "~6.0.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  }
}
