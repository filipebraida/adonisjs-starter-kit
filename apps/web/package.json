    "#auth/*": "./app/auth/*.js",
    "#users/*": "./app/users/*.js",
    "#marketing/*": "./app/marketing/*.js",
    "#analytics/*": "./app/analytics/*.js",
    "#providers/*": "./providers/*.js",
    "#tests/*": "./tests/*.js",
    "#generated/*": "./.adonisjs/server/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
